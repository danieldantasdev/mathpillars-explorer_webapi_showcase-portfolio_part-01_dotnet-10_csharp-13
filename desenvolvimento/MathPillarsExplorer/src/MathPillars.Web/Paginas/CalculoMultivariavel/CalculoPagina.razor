@page "/calculo"
@using MathPillars.Comum.Contratos; using MathPillars.Comum.Modulos.CalculoMultivariavel
@inject ClienteMathCore Cliente
@inject IJSRuntime JS

<PageTitle>Calculo Multivariavel | MathPillars</PageTitle>

<h1 style="margin-bottom: 0.5rem;">Calculo Multivariavel</h1>
<p style="color: var(--cor-texto-secundario); margin-bottom: 3rem;">Explorando gradientes, otimizacao e superficies de custo.</p>

<div style="display: flex; gap: 1rem; margin-bottom: 2rem; overflow-x: auto; padding-bottom: 0.5rem;">
    <button class="@(ExperimentoAtivo == "Landscape" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Landscape"'>Loss Landscape</button>
    <button class="@(ExperimentoAtivo == "Gradiente" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Gradiente"'>Gradiente</button>
    <button class="@(ExperimentoAtivo == "Jacobiana" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Jacobiana"'>Jacobiana</button>
    <button class="@(ExperimentoAtivo == "Otimizadores" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Otimizadores"'>Otimizadores</button>
</div>

@if (ExperimentoAtivo == "Landscape")
{
    <PainelTeoria Titulo="Loss Landscapes e Otimizacao">
        <p>Em IA, visualizamos a funcao de erro como uma superficie. O objetivo e encontrar o ponto mais baixo.</p>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Superficie de Custo</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div><label>X Min</label><input type="number" @bind="MinX" class="input-premium" /></div>
            <div><label>X Max</label><input type="number" @bind="MaxX" class="input-premium" /></div>
            <div><label>Y Min</label><input type="number" @bind="MinY" class="input-premium" /></div>
            <div><label>Y Max</label><input type="number" @bind="MaxY" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="GerarSuperficie" disabled="@Calculando">Gerar Mapa 3D</button>
        <div id="grafico-loss" style="height: 500px; width: 100%; margin-top: 2rem;"></div>
    </div>
}
else if (ExperimentoAtivo == "Gradiente")
{
    <PainelTeoria Titulo="Gradiente Descendente">
        <p>O gradiente aponta para a direcao de maior subida. Seguimos o oposto para minimizar.</p>
        <div class="formula-matematica" style="text-align: center;">$$\theta_{t+1} = \theta_t - \eta \nabla J(\theta_t)$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Calculo de Inclinacao Local</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div><label>Ponto X</label><input type="number" @bind="PontoX" class="input-premium" /></div>
            <div><label>Ponto Y</label><input type="number" @bind="PontoY" class="input-premium" /></div>
        </div>
        <button class="botao-primario" style="margin-top: 1.5rem;" @onclick="CalcularGradiente">Calcular Vetor Gradiente</button>
        
        @if (vetorGradiente != null)
        {
            <div style="margin-top: 2rem;">
                <div class="resultado-box-verde">
                    <h6>Vetor Gradiente $\nabla f$</h6>
                    <h3>[@string.Join(", ", vetorGradiente.Componentes.Select(c => c.ToString("F4")))]</h3>
                </div>
            </div>
        }
    </div>
}
else if (ExperimentoAtivo == "Jacobiana")
{
    <PainelTeoria Titulo="Matriz Jacobiana">
        <p>A Jacobiana e a generalizacao do gradiente para funcoes vetoriais, essencial no Backpropagation.</p>
        <div class="formula-matematica" style="text-align: center;">$$J = \begin{bmatrix} \frac{\partial f_1}{\partial x_1} & \cdots & \frac{\partial f_1}{\partial x_n} \\ \vdots & \ddots & \vdots \end{bmatrix}$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Linearizacao de Sistemas</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
            <div><label>Ponto X</label><input type="number" @bind="PontoJacobianaX" class="input-premium" /></div>
            <div><label>Ponto Y</label><input type="number" @bind="PontoJacobianaY" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="CalcularJacobiana">Computar Jacobiana</button>
        
        @if (resultadoJacobiana != null)
        {
            <div style="margin-top: 2rem;">
                <div class="resultado-box-verde">
                    <h6>Matriz Jacobiana $J$</h6>
                    <h3>@resultadoJacobiana.Linhas x @resultadoJacobiana.Colunas</h3>
                </div>
            </div>
        }
    </div>
}
else if (ExperimentoAtivo == "Otimizadores")
{
    <PainelTeoria Titulo="AdamW vs Sophia">
        <p>Compare otimizadores de primeira ordem (AdamW) com otimizadores de segunda ordem (Sophia).</p>
        <div class="formula-matematica" style="text-align: center;">$$\text{Sophia: } \theta_{t+1} = \theta_t - \eta \cdot \frac{m_t}{h_t}$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Convergencia Comparativa</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div>
                <label>Funcao de Custo</label>
                <select @bind="FuncaoSelecionada" class="input-premium">
                    <option value="Rosenbrock">Rosenbrock</option>
                    <option value="Quadratica">Quadratica ($x^2 + y^2$)</option>
                </select>
            </div>
            <div><label>Learning Rate</label><input type="number" step="0.001" @bind="LearningRate" class="input-premium" /></div>
            <div><label>Iteracoes</label><input type="number" step="10" @bind="Iteracoes" class="input-premium" /></div>
            <div><label>X Inicial</label><input type="number" @bind="XIni" class="input-premium" /></div>
            <div><label>Y Inicial</label><input type="number" @bind="YIni" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="CompararOtimizadores" disabled="@Calculando">Iniciar Comparacao</button>
        <ProgressoSSE Visivel="@Calculando" Percentual="@ProgressoOtim" Mensagem="@MensagemOtim" />
        
        @if (resultadoOtimizadores != null)
        {
            <div style="margin-top: 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="resultado-box-verde" style="background-color: var(--cor-primaria);">
                    <h6>Iteracoes AdamW</h6>
                    <h3>@resultadoOtimizadores.TrajetoriaAdamW.Length</h3>
                </div>
                <div class="resultado-box-verde">
                    <h6>Iteracoes Sophia</h6>
                    <h3>@resultadoOtimizadores.TrajetoriaSophia.Length</h3>
                </div>
            </div>
        }
    </div>
}

<style>
    .input-premium { width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--cor-borda); background: white; }
    .resultado-box-verde { background-color: var(--cor-sucesso); color: white; padding: 1.5rem; border-radius: 12px; }
    .botao-secundario { background: transparent; border: 1px solid var(--cor-borda); padding: 0.6rem 1.2rem; border-radius: 8px; cursor: pointer; transition: all 0.2s; }
    .botao-secundario:hover { background: var(--cor-primaria-suave); }
</style>

@code {
    private string _experimentoAtivo = "Landscape";
    private string ExperimentoAtivo 
    { 
        get => _experimentoAtivo; 
        set 
        { 
            _experimentoAtivo = value; 
            _ = Task.Run(async () => { await Task.Delay(100); await JS.InvokeVoidAsync("renderizarMatematica"); });
        } 
    }
    private bool Calculando = false;

    // Landscape
    private double MinX = -2, MaxX = 2, MinY = -1, MaxY = 3;

    // Gradiente
    private double PontoX = 1, PontoY = 1;
    private MathPillars.Comum.Primitivos.Vetor? vetorGradiente;

    // Jacobiana
    private double PontoJacobianaX = 1.0, PontoJacobianaY = 1.0;
    private MathPillars.Comum.Primitivos.Matriz? resultadoJacobiana;

    // Otimizadores
    private string FuncaoSelecionada = "Rosenbrock";
    private double LearningRate = 0.01;
    private int Iteracoes = 100;
    private double XIni = -1.5, YIni = 2.5;
    private int ProgressoOtim = 0;
    private string MensagemOtim = "";
    private ResultadoComparacaoOtimizadores? resultadoOtimizadores;

    private async Task GerarSuperficie()
    {
        Calculando = true;
        var url = $"api/calculo/loss-landscape/stream?funcaoNome=rosenbrock&minX={MinX}&maxX={MaxX}&minY={MinY}&maxY={MaxY}";
        var pontos = new List<PontoSuperficie3D>();
        await foreach (var ev in Cliente.ObterStreamSSE<ResultadoSSE<PontoSuperficie3D[]>>(url))
        {
            if (ev.DadosParciais != null) pontos.AddRange(ev.DadosParciais);
        }
        await JS.InvokeVoidAsync("renderizarGrafico3D", "grafico-loss", pontos);
        Calculando = false;
    }

    private async Task CalcularGradiente()
    {
        vetorGradiente = await Cliente.PostAsync<RequisicaoGradiente, MathPillars.Comum.Primitivos.Vetor>("api/calculo/gradiente", new("rosenbrock", new[] { PontoX, PontoY }));
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    private async Task CalcularJacobiana()
    {
        resultadoJacobiana = await Cliente.PostAsync<RequisicaoJacobiana, MathPillars.Comum.Primitivos.Matriz>("api/calculo/jacobiana", new("sistema-base", new[] { PontoJacobianaX, PontoJacobianaY }));
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    private async Task CompararOtimizadores()
    {
        Calculando = true; resultadoOtimizadores = null; ProgressoOtim = 0;
        var url = $"api/calculo/otimizador/comparar/stream?funcaoNome={FuncaoSelecionada}&xInicial={XIni}&yInicial={YIni}&learningRate={LearningRate}&iteracoes={Iteracoes}";
        await foreach (var ev in Cliente.ObterStreamSSE<ResultadoSSE<ResultadoComparacaoOtimizadores>>(url))
        {
            ProgressoOtim = ev.ProgressoPercentual; MensagemOtim = ev.MensagemProgresso;
            if (ev.Concluido) resultadoOtimizadores = ev.DadosParciais;
            StateHasChanged();
        }
        Calculando = false;
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("renderizarMatematica");
    }
}
