@page "/calculo"
@using MathPillars.Comum.Contratos; using MathPillars.Comum.Modulos.CalculoMultivariavel
@inject ClienteMathCore Cliente
@inject IJSRuntime JS

<PageTitle>Calculo Multivariavel | MathPillars</PageTitle>

<h1 style="margin-bottom: 0.5rem;">Calculo Multivariavel</h1>
<p style="color: var(--cor-texto-secundario); margin-bottom: 3rem;">Explorando gradientes, otimizacao e superficies de custo.</p>

<PainelTeoria Titulo="Loss Landscapes e Otimizacao">
    <p>Em Aprendizado de Maquina, otimizar um modelo significa encontrar o minimo de uma funcao de custo (Loss Function). Esta funcao pode ser visualizada como uma paisagem em 3D.</p>
    <div class="formula-matematica" style="text-align: center;">
        $$f(x, y) = (1 - x)^2 + 100(y - x^2)^2$$
    </div>
    <p style="margin-top: 1rem;">A funcao acima e a de **Rosenbrock**, famosa por seu vale estreito e curvo onde o minimo global ($1, 1$) e dificil de encontrar para muitos algoritmos.</p>
</PainelTeoria>

<div class="cartao-premium">
    <h4>Experimento: Geracao de Loss Landscape Dinamica</h4>
    <p style="font-size: 0.85rem; color: var(--cor-texto-secundario); margin: 1rem 0;">Ajuste os limites do dominio para visualizar diferentes regioes da funcao de Rosenbrock.</p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div>
            <label style="display: block; font-size: 0.8rem; margin-bottom: 0.5rem; font-weight: 600;">X Minimo</label>
            <input type="number" step="0.1" @bind="MinX" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--cor-borda);" />
        </div>
        <div>
            <label style="display: block; font-size: 0.8rem; margin-bottom: 0.5rem; font-weight: 600;">X Maximo</label>
            <input type="number" step="0.1" @bind="MaxX" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--cor-borda);" />
        </div>
        <div>
            <label style="display: block; font-size: 0.8rem; margin-bottom: 0.5rem; font-weight: 600;">Y Minimo</label>
            <input type="number" step="0.1" @bind="MinY" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--cor-borda);" />
        </div>
        <div>
            <label style="display: block; font-size: 0.8rem; margin-bottom: 0.5rem; font-weight: 600;">Y Maximo</label>
            <input type="number" step="0.1" @bind="MaxY" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--cor-borda);" />
        </div>
    </div>

    <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
        <button class="botao-primario" @onclick="GerarSuperficie" disabled="@Calculando">
            @(Calculando ? "Calculando..." : "Gerar Superficie 3D (SSE)")
        </button>
    </div>

    <ProgressoSSE Visivel="@Calculando" Percentual="@Progresso" Mensagem="@Mensagem" />

    @if (Pontos != null)
    {
        <div style="margin-top: 2rem;">
            <div id="grafico-loss-landscape" style="width: 100%; height: 600px; border-radius: 12px; overflow: hidden; background: #f8f9fa;"></div>
            <p style="font-size: 0.8rem; color: var(--cor-texto-secundario); margin-top: 1rem; text-align: center;">
                Superficie gerada com @Pontos.Length pontos. Visualizacao 3D interativa via Plotly.js.
            </p>
        </div>
    }
</div>

@code {
    private double MinX = -2.0;
    private double MaxX = 2.0;
    private double MinY = -1.0;
    private double MaxY = 3.0;

    private bool Calculando = false;
    private int Progresso = 0;
    private string Mensagem = "";
    private PontoSuperficie3D[]? Pontos;
    private CancellationTokenSource? _cts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !Calculando)
        {
            await JS.InvokeVoidAsync("renderizarMatematica");
        }
    }

    private async Task GerarSuperficie()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        
        Calculando = true;
        Pontos = null;
        Progresso = 0;
        Mensagem = "Calculando topografia da superficie...";
        StateHasChanged();

        var url = $"api/calculo/loss-landscape/stream?funcaoNome=rosenbrock&minX={MinX.ToString(System.Globalization.CultureInfo.InvariantCulture)}&maxX={MaxX.ToString(System.Globalization.CultureInfo.InvariantCulture)}&minY={MinY.ToString(System.Globalization.CultureInfo.InvariantCulture)}&maxY={MaxY.ToString(System.Globalization.CultureInfo.InvariantCulture)}";

        try
        {
            await foreach (var evento in Cliente.ObterStreamSSE<ResultadoSSE<PontoSuperficie3D[]>>(url).WithCancellation(_cts.Token))
            {
                Progresso = evento.ProgressoPercentual;
                Mensagem = evento.MensagemProgresso;
                
                if (evento.Concluido && evento.DadosParciais != null)
                {
                    Pontos = evento.DadosParciais;
                    StateHasChanged();
                    await Task.Delay(200); // Garantir render do div
                    await JS.InvokeVoidAsync("renderizarGrafico3D", "grafico-loss-landscape", Pontos);
                }
                
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Mensagem = "Erro: " + ex.Message;
        }
        finally
        {
            Calculando = false;
            StateHasChanged();
        }
    }
}
