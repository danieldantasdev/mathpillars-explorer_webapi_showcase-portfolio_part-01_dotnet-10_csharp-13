@page "/probabilidade"
@using MathPillars.Comum.Contratos; using MathPillars.Comum.Modulos.Probabilidade
@inject ClienteMathCore Cliente
@inject IJSRuntime JS

<PageTitle>Probabilidade e Bayes | MathPillars</PageTitle>

<h1 style="margin-bottom: 0.5rem;">Teoria da Probabilidade</h1>
<p style="color: var(--cor-texto-secundario); margin-bottom: 3rem;">Inferencia Bayesiana e distribuicoes de probabilidade.</p>

<div style="display: flex; gap: 1rem; margin-bottom: 2rem; overflow-x: auto; padding-bottom: 0.5rem;">
    <button class="@(ExperimentoAtivo == "Bayes" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Bayes"'>Bayes</button>
    <button class="@(ExperimentoAtivo == "Gaussiana" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Gaussiana"'>Gaussiana</button>
    <button class="@(ExperimentoAtivo == "Poisson" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Poisson"'>Poisson</button>
    <button class="@(ExperimentoAtivo == "Entropia" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Entropia"'>Entropia Cruzada</button>
    <button class="@(ExperimentoAtivo == "Markov" ? "botao-primario" : "botao-secundario")" @onclick='() => ExperimentoAtivo = "Markov"'>Markov</button>
</div>

@if (ExperimentoAtivo == "Bayes")
{
    <PainelTeoria Titulo="Teorema de Bayes">
        <p>Atualizacao de crencas baseada em novas evidencias.</p>
        <div class="formula-matematica" style="text-align: center;">$$P(H|E) = \frac{P(E|H) \cdot P(H)}{P(E)}$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Inferencia Bayesiana</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div><label>Prior P(H)</label><input type="number" step="0.01" @bind="Prior" class="input-premium" /></div>
            <div><label>Verossimilhanca P(E|H)</label><input type="number" step="0.01" @bind="Verossimilhanca" class="input-premium" /></div>
            <div><label>Falso Positivo</label><input type="number" step="0.01" @bind="FalsoPositivo" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="CalcularBayes">Calcular Posterior</button>
        
        @if (resultadoBayes != null)
        {
            <div style="margin-top: 2rem;">
                <div class="resultado-box-verde">
                    <h6>Posterior Calculada $P(H|E)$</h6>
                    <h3>@resultadoBayes.ProbabilidadePosterior.ToString("P2")</h3>
                </div>
            </div>
        }
    </div>
}
else if (ExperimentoAtivo == "Gaussiana")
{
    <PainelTeoria Titulo="Distribuicao Normal (Gaussiana)">
        <p>A curva em sino que descreve a maioria dos fenomenos naturais e erros em IA.</p>
        <div class="formula-matematica" style="text-align: center;">$$f(x) = \frac{1}{\sigma\sqrt{2\pi}} e^{-\frac{1}{2}(\frac{x-\mu}{\sigma})^2}$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Curva de Densidade</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div><label>Media (μ)</label><input type="number" @bind="Media" class="input-premium" /></div>
            <div><label>Desvio Padrao (σ)</label><input type="number" @bind="Desvio" class="input-premium" /></div>
        </div>
        <button class="botao-primario" style="margin-top: 1.5rem;" @onclick="GerarGaussiana">Plotar Curva</button>
        <div id="grafico-gauss" style="height: 400px; width: 100%; margin-top: 2rem;"></div>
    </div>
}
else if (ExperimentoAtivo == "Poisson")
{
    <PainelTeoria Titulo="Distribuicao de Poisson">
        <p>Utilizada para modelar o numero de eventos que ocorrem em um intervalo fixo de tempo ou espaco.</p>
        <div class="formula-matematica" style="text-align: center;">$$P(X=k) = \frac{e^{-\lambda} \lambda^k}{k!}$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Eventos Raros</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <div><label>Taxa de Ocorrencia ($\lambda$)</label><input type="number" step="0.5" @bind="LambdaPoisson" class="input-premium" /></div>
            <div><label>Numero de Eventos (k)</label><input type="number" @bind="KPoisson" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="CalcularPoisson">Calcular Probabilidade</button>

        @if (resultadoPoisson != null)
        {
            <div style="margin-top: 2rem;">
                <div class="resultado-box-verde">
                    <h6>Probabilidade $P(X=k)$</h6>
                    <h3>@resultadoPoisson.Value.ToString("P4")</h3>
                </div>
            </div>
        }
    </div>
}
else if (ExperimentoAtivo == "Entropia")
{
    <PainelTeoria Titulo="Entropia Cruzada (Cross-Entropy)">
        <p>Mede a disparidade entre a distribuicao real e a predita pelo modelo de IA.</p>
        <div class="formula-matematica" style="text-align: center;">$$H(p, q) = -\sum_{x} p(x) \log q(x)$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Perda de Classificacao</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <div><label>Distribuicao Real (P) - ex: 1, 0, 0</label><input @bind="EntropiaRealTexto" class="input-premium" /></div>
            <div><label>Predicao Modelo (Q) - ex: 0.7, 0.2, 0.1</label><input @bind="EntropiaPreditaTexto" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="CalcularEntropia">Calcular Loss</button>
        
        @if (resultadoEntropia != null)
        {
            <div style="margin-top: 2rem;">
                <div class="resultado-box-verde">
                    <h6>Valor da Entropia</h6>
                    <h3>@resultadoEntropia.EntropiaCruzada.ToString("F6")</h3>
                </div>
            </div>
        }
    </div>
}
else if (ExperimentoAtivo == "Markov")
{
    <PainelTeoria Titulo="Cadeias de Markov">
        <p>Modelagem de sistemas que evoluem de um estado para outro com probabilidades fixas.</p>
        <div class="formula-matematica" style="text-align: center;">$$P(X_{t+1} | X_t, \dots, X_0) = P(X_{t+1} | X_t)$$</div>
    </PainelTeoria>

    <div class="cartao-premium">
        <h4>Laboratorio: Processos Estocasticos (2 Estados)</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <div><label>Estado 0 → 0</label><input type="number" step="0.1" @bind="M00" class="input-premium" /></div>
            <div><label>Estado 0 → 1</label><input type="number" step="0.1" @bind="M01" class="input-premium" /></div>
            <div><label>Estado 1 → 0</label><input type="number" step="0.1" @bind="M10" class="input-premium" /></div>
            <div><label>Estado 1 → 1</label><input type="number" step="0.1" @bind="M11" class="input-premium" /></div>
            <div><label>Numero de Passos</label><input type="number" @bind="PassosMarkov" class="input-premium" /></div>
            <div><label>Estado Inicial</label><input type="number" min="0" max="1" @bind="EstadoInicialMarkov" class="input-premium" /></div>
        </div>
        <button class="botao-primario" @onclick="SimularMarkov">Simular Processo</button>
        
        @if (resultadoMarkov != null)
        {
            <div style="margin-top: 2rem;">
                <div class="resultado-box-verde">
                    <h6>Distribuicao Estacionaria (Estado 0 / Estado 1)</h6>
                    <h3>@resultadoMarkov.DistribuicaoFinal[0].ToString("P1") / @resultadoMarkov.DistribuicaoFinal[1].ToString("P1")</h3>
                </div>
            </div>
        }
    </div>
}

<style>
    .input-premium { width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--cor-borda); background: white; }
    .resultado-box-verde { background-color: var(--cor-sucesso); color: white; padding: 1.5rem; border-radius: 12px; }
    .botao-secundario { background: transparent; border: 1px solid var(--cor-borda); padding: 0.6rem 1.2rem; border-radius: 8px; cursor: pointer; transition: all 0.2s; }
</style>

@code {
    private string _experimentoAtivo = "Bayes";
    private string ExperimentoAtivo 
    { 
        get => _experimentoAtivo; 
        set 
        { 
            _experimentoAtivo = value; 
            _ = Task.Run(async () => { await Task.Delay(100); await JS.InvokeVoidAsync("renderizarMatematica"); });
        } 
    }

    // Bayes
    private double Prior = 0.01, Verossimilhanca = 0.99, FalsoPositivo = 0.05;
    private ResultadoBayes? resultadoBayes;

    // Gaussiana
    private double Media = 0, Desvio = 1;

    // Poisson
    private double LambdaPoisson = 2.0;
    private int KPoisson = 3;
    private double? resultadoPoisson;

    // Entropia
    private string EntropiaRealTexto = "1, 0, 0";
    private string EntropiaPreditaTexto = "0.7, 0.2, 0.1";
    private ResultadoEntropiaCruzada? resultadoEntropia;
    
    // Markov
    private double M00 = 0.7, M01 = 0.3, M10 = 0.4, M11 = 0.6;
    private int PassosMarkov = 100, EstadoInicialMarkov = 0;
    private ResultadoMarkov? resultadoMarkov;

    private async Task CalcularBayes()
    {
        resultadoBayes = await Cliente.PostAsync<RequisicaoBayes, ResultadoBayes>("api/probabilidade/bayes", new(Prior, Verossimilhanca, FalsoPositivo));
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    private async Task GerarGaussiana()
    {
        var url = $"api/probabilidade/gaussiana/stream?media={Media}&desvioPadrao={Desvio}&min=-5&max=5&pontos=100";
        var pontos = new List<PontoGaussiana>();
        await foreach (var ev in Cliente.ObterStreamSSE<ResultadoSSE<PontoGaussiana[]>>(url))
        {
            if (ev.DadosParciais != null) pontos.AddRange(ev.DadosParciais);
        }
        await JS.InvokeVoidAsync("renderizarGrafico2D", "grafico-gauss", pontos);
    }

    private async Task CalcularPoisson()
    {
        resultadoPoisson = await Cliente.PostAsync<RequisicaoPoisson, double>("api/probabilidade/poisson", new(LambdaPoisson, KPoisson));
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    private async Task CalcularEntropia()
    {
        var p = EntropiaRealTexto.Split(',').Select(double.Parse).ToArray();
        var q = EntropiaPreditaTexto.Split(',').Select(double.Parse).ToArray();
        resultadoEntropia = await Cliente.PostAsync<RequisicaoEntropiaCruzada, ResultadoEntropiaCruzada>("api/probabilidade/entropia-cruzada", new(p, q));
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    private async Task SimularMarkov()
    {
        var matriz = new double[][] {
            new double[] { M00, M01 },
            new double[] { M10, M11 }
        };
        resultadoMarkov = await Cliente.PostAsync<RequisicaoMarkov, ResultadoMarkov>("api/probabilidade/markov", new(matriz, PassosMarkov, EstadoInicialMarkov));
        await Task.Delay(100);
        await JS.InvokeVoidAsync("renderizarMatematica");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("renderizarMatematica");
    }
}
